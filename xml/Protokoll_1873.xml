   <text>
      <body>
         <pb n="1" facs="#pro1873_p1"/>
         <div type="introduction">
            <fw type="archival" place="top-left" rend="ink-red">I.N. 194.906</fw>
            <head>
               <choice>
                  <orig>Protocoll</orig>
                  <reg>Protokoll</reg>
               </choice>
            </head>
            <p>der am <date when="1873-09-05">5. September 1873</date> im <choice>
                  <orig>Bureau</orig>
                  <reg>Büro</reg>
               </choice> des <persName ref="personen.xml#pe_schey">
                  <roleName type="honorific">Herrn</roleName><lb/>
                  <roleName type="nobility">Baron</roleName>Fr. von Schey</persName> abgehaltenen
               Sitzung<lb/> in <orgName ref="organisationen.xml#org_wal">Wienableitungs &amp; <choice>
                     <orig>Localbahnen</orig>
                     <reg>Lokalbahnen</reg>
                  </choice></orgName><lb/>
               <choice>
                  <orig>Projects=Angelegenheiten</orig>
                  <reg>Projektangelegenheiten</reg>
               </choice>. </p>
         </div>

         <div type="attendees">
            <head>Anwesende:</head>
            <list>
               <item><persName ref="personen.xml#pe_zichy">
                     <roleName type="nobility">Graf</roleName>Edmund Zichy</persName></item>
               <item><persName ref="personen.xml#pe_schwarz">
                     <roleName type="nobility">Baron</roleName> C. von Schwarz</persName></item>
               <!-- Supplied gibt an, dass das Wort physisch dort nicht steht. reason=""ditto" erklärt warum es ergänzt wurde. evidence woher es kommt. seg rend gibt das ersetzte Zeichen an.-->
               <item><persName ref="personen.xml#pe_schey"><supplied reason="ditto"
                        evidence="previous-item">Baron</supplied>
                     <seg rend="ditto">"</seg>Fr. von Schey</persName></item>
               <item><persName ref="personen.xml#pe_wagner">Otto Wagner</persName></item>
               <item><persName ref="personen.xml#pe_scheyrer">Georg Scheyrer</persName></item>
            </list>
         </div>

         <div type="speaker">
            <sp>
               <speaker><persName ref="personen.xml#pe_schwarz">
                     <roleName type="nobility">Baron</roleName>Schwarz</persName>
               </speaker>
               <p><choice>
                     <orig>theilt</orig>
                     <reg>teilt</reg>
                  </choice> mit, daß die <orgName ref="organisationen.xml#org_ca"> Credit-<lb
                        break="no"/>Anstalt</orgName> geneigt ist, in das<lb/> Geschäft
                  einzutreten.</p>
            </sp>

            <sp>
               <speaker>
                  <persName ref="personen.xml#pe_wagner">Otto Wagner</persName>
               </speaker>
               <p><choice>
                     <orig>theilt</orig>
                     <reg>teilt</reg>
                  </choice> mit, daß das <choice>
                     <orig>Project</orig>
                     <reg>Projekt</reg>
                  </choice><lb/> in der gestrigen <choice>
                     <orig>Commissions-<lb break="no"/> Sitzung</orig>
                     <reg>Kommissions-<lb break="no"/>sitzung</reg>
                  </choice> des <choice>
                     <orig>Gemeinderathes</orig>
                     <reg>Gemeinderats</reg>
                  </choice><lb/> mit Stimmeneinhelligkeit<lb/> durchgegangen ist.</p>
            </sp>
         </div>

         <pb n="2" facs="#pro1873_p2"/>
         <div type="table">
            <p>Die <choice>
                  <orig>Antheile</orig>
                  <reg>Anteile</reg>
               </choice> werden folgenderweise festgesetzt:</p>
            <table>
               <row>
                  <cell><orgName ref="organisationen.xml#org_ca"> Credit-Anstalt</orgName>
                  </cell>
                  <cell><measure type="share" quantity="40" unit="percent">40 %</measure></cell>
               </row>
               <row>
                  <cell><persName ref="personen.xml#pe_schwarz"><roleName type="nobility"
                           >Baron</roleName> Schwarz</persName></cell>
                  <cell><measure type="share" quantity="10" unit="percent">10 %</measure></cell>
               </row>

               <row>
                  <cell><persName ref="personen.xml#pe_zichy"><roleName type="nobility"
                           >Graf</roleName> Zichy</persName></cell>
                  <cell><measure type="share" quantity="8" unit="percent">8 %</measure></cell>
               </row>
               <row>
                  <cell><persName ref="personen.xml#pe_schey"><roleName type="nobility"
                           >Baron</roleName> Schey</persName></cell>
                  <cell><measure type="share" quantity="9" unit="percent">9 %</measure></cell>
               </row>
               <row>
                  <cell><persName ref="personen.xml#pe_melingo">A. von Melingo</persName></cell>
                  <cell><measure type="share" quantity="8" unit="percent">8 %</measure></cell>
               </row>
               <row>
                  <cell><persName ref="personen.xml#pe_scheyrer">Georg Scheyrer</persName></cell>
                  <cell><measure type="share" quantity="5" unit="percent">5 %</measure></cell>
               </row>
               <row>
                  <cell></cell>
                  <cell><measure type="share" quantity="83" unit="percent">83 %</measure></cell>
               </row>
               <row>
                  <cell><persName ref="personen.xml#pe_wagner">Otto Wagner</persName></cell>
                  <cell><measure type="share" quantity="10" unit="percent">10 %</measure></cell>
               </row>
               <row>
                  <cell></cell>
                  <cell><measure type="share" quantity="93" unit="percent">93 %</measure></cell>
               </row>
               <row>
                  <cell>Reserve</cell>
                  <cell><measure type="share" quantity="7" unit="percent">7 %</measure></cell>
               </row>
               <row>
                  <cell></cell>
                  <cell><measure type="share" quantity="100" unit="percent">100 %</measure></cell>
               </row>
            </table>
         </div>
         <div type="speaker">
            <sp>
               <speaker><persName ref="personen.xml#pe_schwarz"><roleName type="nobility"
                        >Baron</roleName> Schwarz</persName></speaker>
               <p>stellt den Antrag, für den Fall,<lb/>
                  <fw type="library-stamp" rend="middle-right ink-dark-blue"> Wiener Stadt <gap
                        reason="illegible"/>
                  </fw> als die <choice>
                     <orig>Betheiligung</orig>
                     <reg>Beteiligung</reg>
                  </choice> des <persName ref="personen.xml#pe_rothschild"><roleName type="nobility"
                        >Baron.</roleName><lb break="no"/> Rothschild</persName> angenommen
                  wird,<lb/> daß diese <choice>
                     <orig>Betheiligung</orig>
                     <reg>Beteiligung</reg>
                  </choice> pro rata<lb/>
                  <hi rend="underline-black">von allen Theilnehmern</hi> getra-<lb break="no"/> gen
                  werde, selbstverständlich auch<lb/> von <choice>
                     <orig>Antheilen</orig>
                     <reg>Anteilen</reg>
                  </choice> der <orgName ref="organisationen.xml#or_ca">Credit-Anstalt</orgName>.<lb/> Der <choice>
                     <orig>Antheil</orig>
                     <reg>Anteil</reg>
                  </choice> des <persName ref="personen.xml#pe_rothschild"><roleName type="nobility"
                        >Baron</roleName>Rothschild</persName><lb/> soll jedoch 10 % nicht
                  überschreiten.</p>
            </sp>
         </div>

         <div type="text">
            <p>Dieser Antrag wird angenommen.</p>
            <p>Es wird <choice>
                  <orig>beschloßen</orig>
                  <reg>beschlossen</reg>
               </choice>, daß <persName ref="personen.xml#pe_schwarz"><roleName type="honorific"
                     >Herr</roleName>
                  <roleName type="nobility">Baron</roleName>Schwarz</persName> die<lb/>
               Unterhandlungen mit der <orgName ref="organisationen.xml#org_ca"> Credit-Anstalt</orgName> leiten<lb/> wird, und daß <persName ref="personen.xml#pe_wagner"><roleName
                     type="honorific">Herr</roleName>Otto Wagner</persName>
               <choice>
                  <orig>assistiren</orig>
                  <reg>assistieren</reg>
               </choice> soll.</p>
         </div>

         <pb n="3" facs="#pro1873_p3"/>
         <div type="speaker">
            <sp>
               <speaker><persName ref="personen.xml#pe_wagner">Otto Wagner</persName></speaker>
               <p><choice>
                     <orig>theilt</orig>
                     <reg>teilt</reg>
                  </choice> mit, daß <persName ref="personen.xml#pe_loewentahl"><roleName
                        type="nobility">Baron</roleName> Löwentahl</persName><lb/> vom <orgName
                     ref="organisationen.xml#org_gr"><choice>
                        <orig>Gemeinderath</orig>
                        <reg>Gemeinderat</reg>
                     </choice></orgName> als Referent<lb/> gewählt wurde.</p>
            </sp>
            </div>
         <div type="text">
               <p>Es wird beschloßen mit der <choice>
                     <orig>Repartirung</orig>
                     <reg>Repartierung</reg>
                  </choice> der Aus-<lb break="no"/>lagen bis zum <choice>
                     <abbr>def.</abbr>
                     <expan>definitiven</expan>
                  </choice> Beitritt <orgName ref="organisationen.xml#or_ca">der Credit-Anstalt
                  </orgName><lb/> zu warten, dem <persName ref="personen.xml#pe_schwarz"><roleName
                        type="honorific">Herrn</roleName>
                     <roleName type="nobility">Baron</roleName>Schwarz</persName> aber seine<lb/> in <choice>
                     <orig>Projectsangelegenheiten</orig>
                     <reg>Projektsangelegenheiten</reg>
                  </choice> gemachten Auslagen<lb/> zu vergüten.</p>
         </div>

         <div type="signatures">
            <!-- m.p steht für manu propria (mit eigener Hand).-->
            <signed><persName ref="personen.xml#pe_zichy">E. Zichy</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed><persName ref="personen.xml#pe_schwarz">Carl v Schwarz</persName><choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed><persName ref="personen.xml#pe_schey">Fr. v. Schey</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed><persName ref="personen.xml#pe_wagner">Otto Wagner</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed><persName ref="personen.xml#pe_scheyrer">G. Scheyrer</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>
         </div>

         <fw type="library-stamp" rend="middle-left ink-dark-blue"> Wiener Stadtbibliothek <gap
               reason="illegible"/>
         </fw>
      </body>
   </text>
