      <body>
         <pb n="1" facs="#p1"/>
         <p>I. N. 194. 906</p>
         <p>Protocoll</p>
         <p>der am 5. September 1873 im Bureau des Herrn</p>
         <p>Baron Fr. von Schey abgehaltenen Sitzung</p>
         <p>in Wienableitungs &amp; Localbahnen</p>
         <p>Projests=Angelegenheiten.</p>
         
         <div type="Anwesende">
            <head>Anwesende:</head>
            <list>
               <item>Graf Edmund Friohy</item>
               <item>Baron D. von Schwarz</item>
               <item>Fr. von Schey</item>
               <item>Otto Wagner</item>
               <item>Georg Scheyrer</item>   
            </list>
         </div>
         
         <div type="Sprecher">
            <sp>
               <speaker>Baron Schwarz</speaker>
               <p>theilt mit, daß die Credit¬</p>
               <p>Anstalt geneigt ist, in das</p>
               <p>Geschäft einzutreten.</p>
            </sp>
            
            <sp>
               <speaker>Otto Wagner</speaker>
               <p>theilt mit, daß das Projest</p>
               <p>in der gestrigen Commissions¬</p>
               <p>Sitzung des Gemeinderathes</p>
               <p>mit Stimmeneinhelligkeit</p>
               <p>durchgegangen ist.</p>
            </sp>
            <pb n="2" facs="#p2"/>
               <p>Die Antheile werden folgenderweise festgesetzt:</p>
               <table>
                  <row>
                     <!-- &#160 -> Geschütztes Leerzeichen vor dem %-->
                     <cell>Credit-Anstalt</cell>
                     <cell>40&#160;%</cell>
                  </row>
                  <row>
                     <cell>Baron Schwarz</cell>
                     <cell>10&#160;%</cell>
                  </row>
                  
            
               </table>
            <pb n="3" facs="#p3"/>
         </div>
         
