<TEI xmlns="http://www.tei-c.org/ns/1.0">
  <teiHeader>
      <fileDesc>
         <titleStmt>
            <title>Personenregister für die Otto Wagner Dokumente.</title>
            <editor>Michaela Kutschera</editor>
         </titleStmt>
         <publicationStmt><p>Interne Verwendung</p></publicationStmt>
         <sourceDesc>
            <p>Protocoll von 1873</p>
            <p>Testament 1o.Ä.</p>
         </sourceDesc>
      </fileDesc>
     
     <encodingDesc>
        <listPrefixDef>
           <prefixDef ident="wd" matchPattern="(.+)" replacementPattern="https://www.wikidata.org/wiki/$1">
              <p>Verweist auf die Wikidata-Einträge mittels ihrer Q-ID.</p>
           </prefixDef>
        </listPrefixDef>
     </encodingDesc>
  </teiHeader>
  <text>
      <body>
         <listPerson>
            <person xml:id="pe_melingo">
               <idno type="wd">Q60818377</idno>
               <persName type="reg"> <!-- reg als Attributwert steht für Registered oder Regular -->
                  <forename>Achilles</forename>
                  <surname>Melingo</surname>
               </persName>
               <persName type="variant">Achilles von Melingo</persName>
               <note>Achilles von Melingo  geborden 1824 und starb 1889. Er war ein österreichischers Kommunalpolitiker.</note>
            </person>
            
            <person xml:id="pe_rothschild">
               <idno type="wd">Q334120</idno>
               <persName type="reg">
                  <roleName type="nobility">Baron</roleName>
                  <forename>Nathan</forename>
                  <surname>Rothschild</surname>
               </persName>
               <persName type="variant">Nathan Rothschild, 1. Baron Rothschild</persName>
               <persName type="variant">Nathan Rotschild</persName>
               <persName type="variant">Nathan Mayer Rothschild</persName>
               <persName type="variant">Natty Rothschild</persName>
               <note>Baron Nathan Rothschild geboren 1840 und starb 1915 und war ein britisch-jüdischer Bankier und Abgeordneter,
                  der Kredite auch an das Land Österreich vergab.</note>
            </person>
            
            <person xml:id="pe_scheyrer">
               <persName type="reg">
                  <forename>Georg</forename>
                  <surname>Scheyrer</surname>
               </persName>
            </person>
            
            <person xml:id="pe_schey">
               <idno type="wd">Q1461926</idno>
               <persName type="reg">
                  <roleName type="nobility">Baron</roleName>
                  <forename>Friedrich</forename>
                  <nameLink>von</nameLink>
                  <surname>Schey</surname>
                  <addName>von Koromla</addName>
               </persName>
               <persName type="variant">Fr. von Schey</persName>
               <persName type="variant">Friedrich Schey Freiherr von Koromla</persName>
               <persName type="variant">Frederick Freiherr von Schey-Koromla</persName>
               <note>Friedrich von Schey geboren 1815 und starb 1881. Er war ein ungarisch-österreichischers Bankier und Mäzen.</note>
            </person>
            
            <person xml:id="pe_schwarz">
               <idno type="wd">Q1041429</idno>
               <persName type="reg">
                  <roleName type="nobility">Baron</roleName>
                  <forename>Carl</forename>
                  <nameLink>von</nameLink>
                  <surname>Schwarz</surname>
               </persName>
               <persName type="variant">Carl Schwarz</persName>
               <persName type="variant">Karl Schwarz</persName>
               <persName type="variant">Carl Freiherr von Schwarz</persName>
               <note>Baron Carl von Schwarz geboren 1817 und starb 1898. Er war ein österreichischer Bauunternehmer.</note>
            </person>
            
            <person xml:id="pe_wagner" role="main">
               <idno type="wd">Q84287</idno>
            <persName type="reg">
               <forename>Otto</forename>
               <surname>Wagner</surname>
            </persName>
               <persName type="variant">Otto Colomann Wagner</persName>  
               <persName type="variant">Otto Kolomann Wagner</persName> 
               <note>Otto Wagner geboren 1841 und starb 1918. Er war ein österreichischer Arichtekt.</note>
            </person>
            
            <person xml:id="pe_zichy">
               <!-- Es gibt mehrere zur Auswahl und ich weiß nicht welcher richtig ist.-->
               <idno type="wd">Q90886586</idno>
               <persName type="reg">
                  <roleName type="nobility">Graf</roleName>
                  <forename>Edmund</forename>
                  <surname>Zichy</surname>
               </persName>
               <persName type="variant">Edmung Graf Zichy-Vásonykeő</persName>
            </person>
            
      
         </listPerson>
      </body>
