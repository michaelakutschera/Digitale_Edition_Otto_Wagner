                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed>
               <persName ref="personen.xml#pe_schwarz">Carl B. Schwarz</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed>
               <persName ref="personen.xml#pe_schey">Fr. v. Schey</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed>
               <persName ref="personen.xml#pe_melingo">Achilles Melingo</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed>
               <persName ref="personen.xml#pe_wagner">Otto Wagner</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>

            <signed>
               <persName ref="personen.xml#pe_scheyrer">G. Scheyrer</persName>
               <choice>
                  <abbr>m/p</abbr>
                  <expan>manu propria</expan>
               </choice>
            </signed>
         </div>
      </body>
